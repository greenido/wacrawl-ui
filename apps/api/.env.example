# WaCrawl API — copy to `.env` and adjust paths for your machine.

PORT=3001

# WhatsApp Desktop on macOS (shared container); used to derive chat/contacts/media paths when unset.
# Paths starting with ~/ are expanded to your home directory.
WACRAWL_WHATSAPP_CONTAINER=~/Library/Group Containers/group.net.whatsapp.WhatsApp.shared

# Explicit overrides (recommended when automating or using non-default layouts).
WACRAWL_CHAT_DB=~/Library/Group Containers/group.net.whatsapp.WhatsApp.shared/ChatStorage.sqlite
WACRAWL_CONTACTS_DB=~/Library/Group Containers/group.net.whatsapp.WhatsApp.shared/ContactsV2.sqlite
WACRAWL_MEDIA_ROOT=~/Library/Group Containers/group.net.whatsapp.WhatsApp.shared/Message/Media

# Primary SQLite opened by the dashboard (WaCrawl export schema). Defaults to ~/.wacrawl/wacrawl.db when unset.
# Point this at your synced archive from `wacrawl sync`; leaving only Chat DB paths above does not switch schema automatically.
WACRAWL_DB=~/.wacrawl/wacrawl.db

# Optional: JSON path for UI-saved overrides (defaults to ~/.wacrawl/dashboard-paths.json).
# WACRAWL_PATHS_FILE=~/.wacrawl/dashboard-paths.json
